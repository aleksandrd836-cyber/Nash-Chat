# Copy this file to .env and fill values from Supabase Dashboard.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Optional overrides.
# Web builds use a same-origin proxy at /_supabase by default.
# VITE_SUPABASE_PROXY_PATH=/_supabase
# VITE_SUPABASE_BROWSER_URL=https://your-domain.example/_supabase
