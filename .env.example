# Copy this file to .env and fill values from Supabase Dashboard.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Optional voice-session HTTP proxying.
# GitHub Pages cannot serve this by itself, so set one of these only when a real
# proxy exists on Vercel, Cloudflare Workers, Netlify Functions, or your server.
# VITE_SUPABASE_PROXY_PATH=/proxy/supabase
# VITE_SUPABASE_PROXY_URL=https://your-proxy.example/supabase
