# Copy this file to .env and fill values from Supabase Dashboard.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Optional overrides for voice-session HTTP proxying.
# Web builds proxy voice session REST/RPC calls through /proxy/supabase by default.
# VITE_SUPABASE_PROXY_PATH=/proxy/supabase
# VITE_SUPABASE_PROXY_URL=https://your-domain.example/proxy/supabase
